# NOTIFICATION SYSTEM ENVIRONMENT VARIABLES
# Copy this to your .env file and fill in your values

# ===== WEB PUSH NOTIFICATIONS =====
# Generate using: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=your_public_vapid_key_here
VAPID_PRIVATE_KEY=your_private_vapid_key_here

# ===== EMAIL NOTIFICATIONS =====
# Email service provider (gmail, outlook, etc.)
EMAIL_SERVICE=gmail

# Email sender address
EMAIL_USER=your_email@gmail.com

# Email password (use App Password for Gmail)
# For Gmail: https://myaccount.google.com/apppasswords
# For other providers: use your email password or app-specific password
EMAIL_PASSWORD=your_app_password_here

# Frontend URL (used in email links)
FRONTEND_URL=http://localhost:3000

# For production:
# FRONTEND_URL=https://yourdomain.com

# ===== EXISTING CONFIGURATION =====
# Keep your existing environment variables below
DATABASE_URL=postgresql://user:password@localhost:5432/assignment_db
JWT_SECRET=your_jwt_secret_key
NODE_ENV=development

# Cloudinary (if using)
CLOUDINARY_NAME=your_cloudinary_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
